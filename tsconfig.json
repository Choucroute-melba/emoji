{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2021",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "sourceMap": true,
    "moduleResolution": "node",
    "jsx": "react",
    "baseUrl": "./src",
    "paths": {
      "@theme/*": ["theme/*"],
      "@src/*": ["*"]
    }
  }
}
